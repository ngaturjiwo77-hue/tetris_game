[app]
title = Tetris Game
package.name = tetrisgame
package.domain = org.tetris
source.dir = .
source.include_exts = py
version = 1.0
requirements = python3,kivy==2.1.0
orientation = portrait
fullscreen = 0
android.permissions = INTERNET
android.api = 30
android.minapi = 21
android.ndk = 25b
android.sdk = 30
android.arch = armeabi-v7a

[buildozer]
log_level = 2
warn_on_root = 0
